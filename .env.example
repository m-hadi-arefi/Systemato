# ── Database ───────────────────────────────────────────────────────────
POSTGRES_DB=systemato
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── App ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production-use-openssl-rand-base64-32
APP_PORT=3000

# ── Kavenegar SMS ──────────────────────────────────────────────────────
KAVENEGAR_API_KEY=your-kavenegar-api-key
KAVENEGAR_OTP_TEMPLATE=systemato-otp
# شماره خط ارسال پیامک متنی (نوتیفیکیشن). اگر خالی باشد خط پیش‌فرض حساب استفاده می‌شود.
KAVENEGAR_SENDER=

# ── MinIO ──────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=systemato-media
# در production این URL باید به domain عمومی MinIO اشاره کند
MINIO_PUBLIC_URL=http://localhost:9000

# ── Cron ───────────────────────────────────────────────────────────────
CRON_SECRET=change-this-cron-secret
