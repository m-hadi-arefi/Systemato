# ═══════════════════════════════════════════════════════════════════════
#  Systemato — نمونه متغیرهای محیطی
#  این فایل را به .env کپی کنید:  cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════

# ── Database ───────────────────────────────────────────────────────────
POSTGRES_DB=systemato
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── App ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# با دستور زیر یک مقدار امن بسازید:  openssl rand -base64 32
NEXTAUTH_SECRET=change-me-in-production
APP_PORT=3000

# ── Kavenegar SMS ──────────────────────────────────────────────────────
KAVENEGAR_API_KEY=your-kavenegar-api-key
KAVENEGAR_OTP_TEMPLATE=systemato-otp
# شماره خط ارسال پیامک متنی (نوتیفیکیشن). خالی = خط پیش‌فرض حساب
KAVENEGAR_SENDER=
# فعال‌سازی ارسال واقعی پیامک. تا وقتی پنل/خط کاوه‌نگار آماده نشده false بماند:
#   false → کد OTP در پاسخ API برمی‌گردد (debug_code) و هیچ SMSی ارسال نمی‌شود
#   true  → همهٔ پیامک‌ها (OTP و نوتیفیکیشن) واقعاً با کاوه‌نگار ارسال می‌شوند
SMS_ENABLED=false

# ── MinIO ──────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=systemato-media
# آدرس عمومی فایل‌ها. فقط scheme+domain (بدون نام باکت).
# فایل‌ها از مسیر https://<domain>/<bucket>/<file> توسط خود اپ سرو می‌شوند.
MINIO_PUBLIC_URL=http://localhost:3000

# ── Cron ───────────────────────────────────────────────────────────────
CRON_SECRET=change-this-cron-secret

# ── Zarinpal درگاه پرداخت ──────────────────────────────────────────────
# کد ۳۶ کاراکتری پذیرنده در پنل زرین‌پال
ZARINPAL_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# آدرس پایه زرین‌پال — برای تست sandbox را تغییر دهید
ZARINPAL_BASE_URL=https://payment.zarinpal.com
# آدرس کامل سایت — برای ساخت callback_url پرداخت استفاده می‌شود
# در محیط لوکال همان NEXTAUTH_URL کافی است؛ در پروداکشن آدرس واقعی بگذارید
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ═══════════════════════════════════════════════════════════════════════
#  راه‌اندازی روی دامنه  →  test.cigex.ir
# ═══════════════════════════════════════════════════════════════════════
#  معماری: فقط پورت ۳۰۰۰ کانتینر app به بیرون باز است. PostgreSQL و MinIO
#  فقط داخل شبکهٔ داکر در دسترس‌اند. فایل‌های MinIO از طریق همان اپ (rewrite
#  روی مسیر /<bucket>/*) سرو می‌شوند، پس نیازی به باز کردن پورت MinIO نیست.
#
#  جلوی کانتینر یک reverse proxy (مثل Nginx/Caddy/Traefik) روی هاست بگذارید
#  که TLS دامنه را مدیریت کند و ترافیک را به 127.0.0.1:3000 بفرستد:
#     test.cigex.ir  ──TLS──▶  reverse-proxy  ──▶  127.0.0.1:3000 (app)
#
#  مقادیر .env برای production:
#
#     POSTGRES_DB=systemato
#     POSTGRES_USER=systemato
#     POSTGRES_PASSWORD=<یک پسورد قوی>
#
#     NEXTAUTH_URL=https://test.cigex.ir
#     NEXTAUTH_SECRET=<خروجی openssl rand -base64 32>
#     APP_PORT=3000
#
#     KAVENEGAR_API_KEY=<کلید واقعی کاوه‌نگار>
#     KAVENEGAR_OTP_TEMPLATE=<نام تمپلیت تأییدشده>
#     KAVENEGAR_SENDER=<شماره خط پیامکی شما>
#
#     MINIO_ROOT_USER=<یوزر دلخواه>
#     MINIO_ROOT_PASSWORD=<یک پسورد قوی>
#     MINIO_BUCKET=systemato-media
#     MINIO_PUBLIC_URL=https://test.cigex.ir
#
#     CRON_SECRET=<یک رشتهٔ تصادفی>
#
#     ZARINPAL_MERCHANT_ID=<کد ۳۶ کاراکتری پذیرنده از پنل زرین‌پال>
#     ZARINPAL_BASE_URL=https://payment.zarinpal.com
#     NEXT_PUBLIC_APP_URL=https://test.cigex.ir
#
#  نمونهٔ بلوک Nginx روی هاست:
#     server {
#       server_name test.cigex.ir;
#       client_max_body_size 5m;           # برای آپلود لوگو
#       location / {
#         proxy_pass http://127.0.0.1:3000;
#         proxy_set_header Host $host;
#         proxy_set_header X-Forwarded-Proto $scheme;
#         proxy_set_header X-Forwarded-For $remote_addr;
#       }
#       # گواهی TLS را با certbot --nginx -d test.cigex.ir بگیرید
#     }
# ═══════════════════════════════════════════════════════════════════════
